# Copy this file to .env and fill in real values before running the server.

# SQLite by default; swap for a postgres:// URL in production.
DATABASE_URL=sqlite:///./jobtrackr.db

# Generate your own with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of allowed frontend origins for CORS.
# Not needed if the backend serves the frontend itself (default setup).
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Optional: enables real AI responses via Claude. Leave blank to use
# the built-in canned fallback responses (no network calls made).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
